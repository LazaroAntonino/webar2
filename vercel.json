{
    "builds": [{
        "src": "package.json",
        "use": "@vercel/static-build",
        "config": { "distDir": "dist" }
    }],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
            ]
        },
        {
            "source": "/sitemap.xml",
            "headers": [
                { "key": "Content-Type", "value": "application/xml" },
                { "key": "Cache-Control", "value": "public, max-age=86400" }
            ]
        },
        {
            "source": "/robots.txt",
            "headers": [
                { "key": "Cache-Control", "value": "public, max-age=86400" }
            ]
        }
    ]
}